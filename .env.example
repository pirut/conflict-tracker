# Required for frontend <-> Convex client connection
NEXT_PUBLIC_CONVEX_URL=

# News ingestion controls (free)
GUARDIAN_API_KEY=
PREFERRED_NEWS_LANGUAGE=en
INCLUDE_NON_ENGLISH_NEWS=true
FOCUS_US_IRAN=true
STRICT_TRUSTED_NEWS=true
MAX_NEWS_AGE_HOURS=72

# NASA EONET satellite events (free, no key)
SATELLITE_DAYS=7
# SATELLITE_BBOX=24,10,67,42

# USGS seismic feed (free, no key)
SEISMIC_WINDOW_HOURS=36
SEISMIC_MIN_MAGNITUDE=2.8
# SEISMIC_BBOX=20,42,41,66

# Open-Meteo anomaly signals (free, no key)
OPEN_METEO_INCLUDE_REGIONAL=true

# AviationWeather METAR anomalies (free, no key)
# Fixed airport list is used in code (Iran + nearby capitals)

# openSenseMap crowd-sensor anomalies (free, no key)
OPENSENSEMAP_BBOX=44,25,63.5,39.8
OPENSENSEMAP_WINDOW_HOURS=8
OPENSENSEMAP_PHENOMENA=PM10,PM2.5
OPENSENSEMAP_NOMINATIM_MAX_PER_RUN=8

# Nominatim reverse geocoding for better place labels (free, no key)
NOMINATIM_REVERSE_ENABLED=true

# Orbital context signals from public TLE feed (free, no key)
ORBITAL_SIGNALS_ENABLED=true
ORBITAL_SIGNALS_PER_TERM=4

# Power outage signals
# Optional direct outage endpoint (if unset, app still emits inferred grid-stress signals from free telemetry)
POWER_OUTAGE_FEED_ENDPOINT=
POWER_OUTAGE_FEED_TOKEN=
POWER_INCLUDE_INFERRED=true

# NASA FIRMS thermal hotspots (optional key; keep blank to skip FIRMS)
FIRMS_API_KEY=
FIRMS_SATELLITE=VIIRS_SNPP_NRT
# Optional: override area bbox (default 44,25,63.5,39.8 = Iran)
# FIRMS_AREA_BBOX=44,25,63.5,39.8

# OpenSky (optional but improves rate limits)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Connectivity signals
CONNECTIVITY_INCLUDE_OONI=true
CONNECTIVITY_FEED_ENDPOINT=
CONNECTIVITY_FEED_TOKEN=

# Optional social ingestion (disabled by default)
ENABLE_SOCIAL_INGESTION=false
SOCIAL_FEED_ENDPOINT=
SOCIAL_FEED_TOKEN=
SOCIAL_REDDIT_ENABLED=true
SOCIAL_X_ENABLED=false
REDDIT_MIN_SCORE=5
REDDIT_MIN_COMMENTS=1
REDDIT_PULLPUSH_MIN_SUBSCRIBERS=75000
REDDIT_USER_AGENT=conflict-tracker/2.0 (+https://localhost)
X_API_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com
X_API_QUERY=
X_API_MAX_RESULTS=50
X_API_LANG=en
X_API_INCLUDE_REPLIES=false

# Optional translation provider
DEEPL_API_KEY=

# AI briefing via OpenRouter
OPEN_ROUTER_API=
OPEN_ROUTER_MODEL=openai/gpt-oss-20b:free
OPEN_ROUTER_MODEL_FALLBACKS=meta-llama/llama-3.3-70b-instruct:free,mistralai/mistral-small-3.1-24b-instruct:free
OPEN_ROUTER_REFERER=http://localhost:3000
OPEN_ROUTER_APP_NAME=Conflict Tracker
NEXT_PUBLIC_ANALYSIS_MIN_REFRESH_MINUTES=35
